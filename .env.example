# Django Settings
DEBUG=False
DJANGO_SECRET_KEY=your-secret-key-here-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com

# PostgreSQL Database (SRS requirement: PostgreSQL 16+ with pgvector)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=gethired
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
# Redis (Celery broker for async ingestion pipeline)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# JWT Configuration
JWT_ALGORITHM=HS256
JWT_ACCESS_LIFETIME=3600
JWT_REFRESH_LIFETIME=604800

# CORS Settings (React Vite dev server)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Split-Data Configuration
PII_HIGH_CONFIDENCE_THRESHOLD=0.7
AUDIT_LOG_RETENTION_DAYS=180

# Security: KMS Key Version (SRS NFR-2.2: rotated every 90 days)
ENCRYPTION_KEY_VERSION=v1

# Embeddings Configuration (SRS 3.3: Embedding Contract)
EMBEDDING_MODEL=text-embedding-3-small
DEFAULT_EMBEDDING_DIMENSION=1536
