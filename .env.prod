# Production environment
# Copy to runtime file:
#   Copy-Item .env.prod .env

# Django Settings
DEBUG=False
DJANGO_SECRET_KEY=replace-with-strong-production-secret
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# Security mode (production)
DJANGO_PRODUCTION=True
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

# Database
DATABASE_URL=postgresql://postgres:replace-me@db-host:5432/gethired

# Resume storage (S3 recommended for production)
RESUME_STORAGE_PREFIX=resumes
AWS_STORAGE_BUCKET_NAME=replace-me
AWS_S3_REGION_NAME=ap-south-1
AWS_S3_ENDPOINT_URL=https://s3.ap-south-1.amazonaws.com
AWS_ACCESS_KEY_ID=replace-me
AWS_SECRET_ACCESS_KEY=replace-me
RESUME_PRESIGNED_URL_EXPIRY_SECONDS=900

# Redis / Celery
CELERY_BROKER_URL=redis://redis-host:6379/0
CELERY_RESULT_BACKEND=redis://redis-host:6379/0

# AI Providers (enable with valid keys)
GEMINI_API_KEY=
GEMINI_ENABLED=False
GEMINI_MODEL=gemini-2.0-flash-lite

OPENROUTER_API_KEY=
OPENROUTER_ENABLED=False
OPENROUTER_MODEL=anthropic/claude-3-haiku

# JWT Configuration
JWT_ALGORITHM=HS256
JWT_ACCESS_LIFETIME=3600
JWT_REFRESH_LIFETIME=604800

# CORS (production frontend origins)
CORS_ALLOWED_ORIGINS=https://yourdomain.com

# Split-Data Configuration
PII_HIGH_CONFIDENCE_THRESHOLD=0.7
AUDIT_LOG_RETENTION_DAYS=180

# Security / embedding config
ENCRYPTION_KEY_VERSION=v1
EMBEDDING_MODEL=text-embedding-3-small
DEFAULT_EMBEDDING_DIMENSION=1536
