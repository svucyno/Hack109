# Template variables shared by .env.dev and .env.prod
# Recommended workflow:
#   Copy-Item .env.dev .env   # local development
#   Copy-Item .env.prod .env  # production runtime

# Django Settings
DEBUG=False
DJANGO_SECRET_KEY=replace-me
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com

# Security mode
DJANGO_PRODUCTION=False
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False

# PostgreSQL Database (single URL form)
DATABASE_URL=postgresql://postgres:replace-me@localhost:5432/gethired

# Resume storage (leave AWS fields empty for local fallback)
RESUME_STORAGE_PREFIX=resumes
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=
AWS_S3_ENDPOINT_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
RESUME_PRESIGNED_URL_EXPIRY_SECONDS=900

# Redis (Celery broker/result backend)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# AI Providers
GEMINI_API_KEY=
GEMINI_ENABLED=False
GEMINI_MODEL=gemini-2.0-flash-lite

OPENROUTER_API_KEY=
OPENROUTER_ENABLED=False
OPENROUTER_MODEL=anthropic/claude-3-haiku

# CORS Settings (React Vite dev server)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Split-Data Configuration
PII_HIGH_CONFIDENCE_THRESHOLD=0.7
AUDIT_LOG_RETENTION_DAYS=180

# Security: KMS Key Version
ENCRYPTION_KEY_VERSION=v1

# Embeddings Configuration
EMBEDDING_MODEL=text-embedding-3-small
DEFAULT_EMBEDDING_DIMENSION=1536
